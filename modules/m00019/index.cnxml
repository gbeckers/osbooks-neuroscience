      <list display="inline" id="list-00001">
        <item>acetylcholinesterase</item>
        <item>alpha motoneurons</item>
        <item>ballistic</item>
        <item>central pattern generators (&amp; generation) collagen fibers (tendon components)</item>
        <item>extrafusal muscle fibers</item>
