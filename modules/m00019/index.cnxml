        <item>intrafusal muscle fibers</item>
        <item>junctional folds</item>
        <item>“knee jerk” reflex</item>
        <item>lower motor neurons (LMNs)</item>
        <item>muscle spindles (spindle fibers)</item>
        <item>Myasthenia Gravis</item>
        <item>nicotinic receptors</item>
